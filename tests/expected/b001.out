-- Test for pglinter B001 rule with file output
CREATE EXTENSION pglinter;
CREATE TABLE my_table_without_pk (
    id INT,
    name TEXT,
    code TEXT,
    enable BOOL DEFAULT TRUE,
    query TEXT,
    warning_level INT,
    error_level INT,
    scope TEXT
);
-- Disable all rules first
SELECT pglinter.disable_all_rules() AS all_rules_disabled;
NOTICE:  🔴 Disabled 21 rule(s)
 all_rules_disabled 
--------------------
                 21
(1 row)

-- Run table check to detect tables without PK
SELECT count(*) AS violation_count
FROM pglinter.get_violations()
WHERE rule_code = 'B001';
 violation_count 
-----------------
               0
(1 row)

-- Test rule management for B001
SELECT pglinter.explain_rule('B001');
NOTICE:  📖 Rule Explanation for B001
============================================================

🎯 Rule Name: HowManyTableWithoutPrimaryKey
📋 Scope: BASE

📝 Message:
table without primary key

🔧 How to Fix:
   1. create a primary key
============================================================
 explain_rule 
--------------
 t
(1 row)

SELECT pglinter.is_rule_enabled('B001') AS is_b001_enabled;
 is_b001_enabled 
-----------------
 f
(1 row)

-- Test with file output
-- Test if file exists
-- Re-enable B001 rule
SELECT pglinter.enable_rule('B001') AS enable_b001;
NOTICE:  ✅ Rule B001 has been enabled
 enable_b001 
-------------
 t
(1 row)

-- Test again with B001 enabled
SELECT count(*) AS violation_count
FROM pglinter.get_violations()
WHERE rule_code = 'B001';
 violation_count 
-----------------
               1
(1 row)

SELECT
    (pg_identify_object(classid, objid, objsubid)).type AS object_type,
    (pg_identify_object(classid, objid, objsubid)).schema AS object_schema,
    (pg_identify_object(classid, objid, objsubid)).name AS object_name,
    (pg_identify_object(classid, objid, objsubid)).identity AS object_identity
FROM pglinter.get_violations()
WHERE rule_code = 'B001';
 object_type | object_schema |     object_name     |      object_identity       
-------------+---------------+---------------------+----------------------------
 table       | public        | my_table_without_pk | public.my_table_without_pk
(1 row)

-- Test with file output
-- Test if file exists
DROP TABLE my_table_without_pk CASCADE;
DROP EXTENSION pglinter CASCADE;
